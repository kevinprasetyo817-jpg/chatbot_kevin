# Ollama AI Configuration
OLLAMA_HOST=https://ollama.com
OLLAMA_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gpt-oss:120b-cloud

# Bot Configuration
AI_TIMEOUT=25000
MAX_HISTORY=10

# Rate Limiting (anti-ban)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000
REPLY_DELAY_MIN=800
REPLY_DELAY_MAX=2000

# Logging
LOG_LEVEL=info

# Railway will default to /data/auth and /data/logs if a volume is mounted.
# You can still override both manually if needed.
SESSION_DIR=./auth
LOG_DIR=./logs

# WhatsApp reconnect watchdog
WA_WATCHDOG_INTERVAL_MS=60000
WA_WATCHDOG_DISCONNECTED_MS=180000
WA_WATCHDOG_STARTING_MS=120000
WA_WATCHDOG_CONNECTED_STALE_MS=120000
